# ===== AI (title / description / tags) =====
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Fallback if Groq fails / rate-limits
OPENROUTER_API_KEY=
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free

# ===== Facebook Page (Graph API) =====
# Long-lived Page Access Token (NOT user token). Generate at developers.facebook.com -> Graph API Explorer
FB_PAGE_ID=
FB_PAGE_ACCESS_TOKEN=

# ===== YouTube Data API v3 =====
# Place client_secret.json (OAuth Desktop credentials) next to run.py. token.json is created automatically.
YT_CLIENT_SECRETS=client_secret.json
YT_TOKEN_FILE=token.json
YT_CATEGORY_ID=22
YT_PRIVACY=public

# ===== Scheduler (humanized posting) =====
FB_POSTS_PER_DAY=4
YT_POSTS_PER_DAY=4
# Window in 24h local time:
ACTIVE_HOUR_START=9
ACTIVE_HOUR_END=23
# Random jitter in minutes added/subtracted to each scheduled post
JITTER_MINUTES=25

# ===== Dashboard =====
DASHBOARD_HOST=127.0.0.1
DASHBOARD_PORT=5000
DASHBOARD_SECRET=change-me

# ===== Niche / content style (used in AI prompts) =====
CONTENT_NICHE=general entertainment
CONTENT_LANGUAGE=English
DEFAULT_HASHTAGS=#shorts #viral #trending
